# LibreChat OCI SQL Explorer - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ==========================================
# LiteLLM Configuration
# ==========================================

# LiteLLM Master Key (generate with: openssl rand -hex 16)
# This key is used to authenticate requests to the LiteLLM proxy
LITELLM_MASTER_KEY=sk-your-master-key-here

# LiteLLM Port (default: 4000)
LITELLM_PORT=4000

# ==========================================
# Oracle Database Configuration
# ==========================================

# Database Connection String
# Format: username/password@host:port/service
# Example: admin/MyPassword123@localhost:1521/FREEPDB1
# For Autonomous Database: admin/MyPassword123@mydb_high
DB_CONNECTION_STRING=username/password@host:port/service

# Database Wallet Path (required for Autonomous Database)
# Path to the directory containing wallet files (cwallet.sso, tnsnames.ora, etc.)
# Example: /home/user/wallet or ./wallet
DB_WALLET_PATH=/path/to/wallet

# ==========================================
# SQLcl MCP Server Configuration
# ==========================================

# SQLcl MCP Server Port (default: 3100)
SQLCL_MCP_PORT=3100

# ==========================================
# OCI Configuration (Optional)
# ==========================================

# If not using ~/.oci/config, you can specify OCI credentials here
# These are used by LiteLLM to authenticate with OCI GenAI

# OCI Compartment ID
# OCI_COMPARTMENT_ID=ocid1.compartment.oc1..xxxxx

# OCI Region
# OCI_REGION=us-chicago-1

# OCI Tenancy ID
# OCI_TENANCY_ID=ocid1.tenancy.oc1..xxxxx

# OCI User ID
# OCI_USER_ID=ocid1.user.oc1..xxxxx

# OCI API Key Fingerprint
# OCI_FINGERPRINT=xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx

# OCI API Key Path
# OCI_API_KEY_PATH=/path/to/oci_api_key.pem

# ==========================================
# LibreChat Configuration
# ==========================================

# MongoDB Connection String (for Docker Compose)
# Default: mongodb://admin:admin123@mongodb:27017/LibreChat?authSource=admin
MONGO_URI=mongodb://admin:admin123@mongodb:27017/LibreChat?authSource=admin

# LibreChat Host (default: 0.0.0.0)
HOST=0.0.0.0

# LibreChat Port (default: 3080)
PORT=3080

# Node Environment (development or production)
NODE_ENV=production

# ==========================================
# Optional: Logging Configuration
# ==========================================

# Log Level (debug, info, warn, error)
LOG_LEVEL=info

# ==========================================
# Optional: Security Configuration
# ==========================================

# JWT Secret (generate with: openssl rand -hex 32)
# JWT_SECRET=your-jwt-secret-here

# Session Secret (generate with: openssl rand -hex 32)
# SESSION_SECRET=your-session-secret-here

# ==========================================
# Notes
# ==========================================

# 1. Never commit this file with actual credentials to version control
# 2. Use strong random keys for all secrets
# 3. Ensure proper file permissions (chmod 600 .env)
# 4. For production, consider using a secrets management service
# 5. Verify all paths are absolute or relative to the project root
